Ansible Role: Prometheus Remote Write Receiver Deployment (Central Cluster)

==========================

defaults/main.yml

==========================

namespace: prometheus_receiver storage_class: "" storage_size: 50Gi prometheus_image: quay.io/prometheus/prometheus:v2.51.2 oauth_proxy_image: quay.io/openshift/origin-oauth-proxy:latest cookie_secret: "{{ generated_cookie_secret }}"

==========================

vars/main.yml

==========================

receiver_tls_secret_name: prometheus-tls-secret receiver_token_secret_name: remote-writer-token

==========================

tasks/main.yml

==========================

name: Create namespace kubernetes.core.k8s: kind: Namespace name: "{{ namespace }}" state: present

name: Create Prometheus ServiceAccount kubernetes.core.k8s: definition: | apiVersion: v1 kind: ServiceAccount metadata: name: prometheus namespace: {{ namespace }}

name: Bind ServiceAccount to system:auth-delegator kubernetes.core.k8s: definition: | apiVersion: rbac.authorization.k8s.io/v1 kind: ClusterRoleBinding metadata: name: prometheus-auth-delegator roleRef: kind: ClusterRole name: system:auth-delegator apiGroup: rbac.authorization.k8s.io subjects: - kind: ServiceAccount name: prometheus namespace: {{ namespace }}

name: Create bearer token for remote writers kubernetes.core.k8s: definition: | apiVersion: v1 kind: ServiceAccount metadata: name: remote-writer namespace: {{ namespace }}



---

apiVersion: v1
  kind: Secret
  metadata:
    name: {{ receiver_token_secret_name }}
    namespace: {{ namespace }}
    annotations:
      kubernetes.io/service-account.name: remote-writer
  type: kubernetes.io/service-account-token

name: Create Prometheus TLS Secret kubernetes.core.k8s: definition: | apiVersion: v1 kind: Secret metadata: name: {{ receiver_tls_secret_name }} namespace: {{ namespace }} type: kubernetes.io/tls data: tls.crt: {{ prometheus_tls_crt }} tls.key: {{ prometheus_tls_key }}

name: Create Prometheus PVC kubernetes.core.k8s: definition: | apiVersion: v1 kind: PersistentVolumeClaim metadata: name: prometheus-data-pvc namespace: {{ namespace }} spec: accessModes: - ReadWriteOnce resources: requests: storage: {{ storage_size }} {% if storage_class %}storageClassName: {{ storage_class }}{% endif %}

name: Create Prometheus ConfigMap kubernetes.core.k8s: definition: | apiVersion: v1 kind: ConfigMap metadata: name: prometheus-config namespace: {{ namespace }} data: prometheus.yml: | global: scrape_interval: 15s scrape_configs: []

name: Deploy Prometheus with OAuth Proxy kubernetes.core.k8s: definition: "{{ lookup('template', 'prometheus-deployment.yaml.j2') }}"

name: Create Service and Route kubernetes.core.k8s: definition: "{{ lookup('template', 'prometheus-service-route.yaml.j2') }}"


==========================

Remote Cluster Manual Configuration

==========================

oc commands for remote cluster setup:

1. Create token secret:

oc create secret generic remote-write-token --from-literal=token=<generated-token> -n openshift-user-workload-monitoring

2. Label secret for mounting into Prometheus:

oc label secret remote-write-token prometheus.openshift.io/remote-write=true -n openshift-user-workload-monitoring

3. Apply ConfigMap:

cat <<EOF | oc apply -f -

apiVersion: v1

kind: ConfigMap

metadata:

name: user-workload-monitoring-config

namespace: openshift-user-workload-monitoring

data:

config.yaml: |

prometheus:

remoteWrite:

- url: "https://prometheus.apps.receiver-cluster.example.com/api/v1/write"

bearerTokenFile: /etc/prometheus/secrets/remote-write-token/token

tlsConfig:

insecureSkipVerify: true

EOF

