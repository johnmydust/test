Here's how the files can be structured and populated:

defaults/main.yaml

monitoring_namespace: user-monitoring

remote_write:
  url: "https://your-remote-prometheus/api/v1/write"
  username: "your_username"
  password: "your_password"

tasks/main.yaml

- name: Configure User Monitoring Stack
  include_tasks: "{{ item }}"
  loop:
    - namespace.yaml
    - kube_state_metrics.yaml
    - node_exporter.yaml
    - prometheus.yaml
    - servicemonitors.yaml

tasks/namespace.yaml

- name: Create monitoring namespace
  k8s:
    api_version: v1
    kind: Namespace
    name: "{{ monitoring_namespace }}"
    state: present

tasks/kube_state_metrics.yaml

- name: Deploy kube-state-metrics
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    src: https://github.com/kubernetes/kube-state-metrics/releases/latest/download/kube-state-metrics.yaml

tasks/node_exporter.yaml

- name: Deploy Node Exporter DaemonSet
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    definition: "{{ lookup('url', 'https://raw.githubusercontent.com/prometheus/node_exporter/master/examples/kubernetes/node-exporter-daemonset.yml', split_lines=False) }}"

tasks/prometheus.yaml

- name: Deploy Prometheus instance
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    definition: "{{ lookup('template', 'prometheus-instance.yaml.j2') }}"

templates/prometheus-instance.yaml.j2

apiVersion: monitoring.coreos.com/v1
kind: Prometheus
metadata:
  name: user-prometheus
  namespace: {{ monitoring_namespace }}
spec:
  replicas: 1
  serviceAccountName: prometheus-user
  serviceMonitorSelector:
    matchLabels:
      user-monitoring: \"true\"
  remoteWrite:
    - url: "{{ remote_write.url }}"
      basicAuth:
        username:
          name: prometheus-remote-write-secret
          key: username
        password:
          name: prometheus-remote-write-secret
          key: password

tasks/servicemonitors.yaml

- name: Create ServiceMonitors for kube-state-metrics and node-exporter
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    definition:
      apiVersion: monitoring.coreos.com/v1
      kind: ServiceMonitor
      metadata:
        name: kube-state-metrics-monitor
        labels:
          user-monitoring: "true"
      spec:
        selector:
          matchLabels:
            app.kubernetes.io/name: kube-state-metrics
        endpoints:
          - port: http-metrics
            interval: 30s

- name: Create Node Exporter ServiceMonitor
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    definition:
      apiVersion: monitoring.coreos.com/v1
      kind: ServiceMonitor
      metadata:
        name: node-exporter-monitor
        labels:
          user-monitoring: "true"
      spec:
        selector:
          matchLabels:
            app: node-exporter
        endpoints:
          - port: metrics
            interval: 30s

Additional Steps:

Create the Kubernetes secret (prometheus-remote-write-secret) separately to store credentials securely.


