apiVersion: monitoring.rhobs/v1
kind: MonitoringStack
metadata:
  name: user-monitoring-stack
  namespace: "{{ monitoring_namespace }}"
spec:
  retention: 24h
  logLevel: info
  remoteWrite:
    - url: "{{ remote_write.url }}"
      basicAuth:
        username:
          name: prometheus-remote-write-secret
          key: username
        password:
          name: prometheus-remote-write-secret
          key: password
Note: MonitoringStack is used here for compatibility with Cluster Observability Operator.

