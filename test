📌 Namespace (tasks/namespace.yaml):
- name: Create observability namespace
  k8s:
    api_version: v1
    kind: Namespace
    name: "{{ namespace }}"
    state: present
📌 RBAC (tasks/rbac.yaml):
- name: Create ServiceAccount
  k8s:
    state: present
    namespace: "{{ namespace }}"
    definition:
      apiVersion: v1
      kind: ServiceAccount
      metadata:
        name: prometheus-user

- name: Create Role and RoleBinding
  k8s:
    state: present
    namespace: "{{ namespace }}"
    definition:
      apiVersion: rbac.authorization.k8s.io/v1
      kind: Role
      metadata:
        name: prometheus-reader
      rules:
      - apiGroups: [""]
        resources: ["pods", "services", "endpoints", "nodes", "namespaces"]
        verbs: ["get", "list", "watch"]

- name: Bind Role to ServiceAccount
  k8s:
    state: present
    namespace: "{{ namespace }}"
    definition:
      apiVersion: rbac.authorization.k8s.io/v1
      kind: RoleBinding
      metadata:
        name: prometheus-reader-binding
      subjects:
      - kind: ServiceAccount
        name: prometheus-user
      roleRef:
        kind: Role
        name: prometheus-reader
        apiGroup: rbac.authorization.k8s.io
📌 Prometheus Operator (tasks/prometheus-operator.yaml):
- name: Deploy Prometheus Operator
  k8s:
    state: present
    namespace: "{{ namespace }}"
    definition: "{{ lookup('url', 'https://raw.githubusercontent.com/prometheus-operator/prometheus-operator/v0.72.0/bundle.yaml') | from_yaml_all }}"
📌 Prometheus Instance (tasks/prometheus-instance.yaml):
- name: Deploy Prometheus Instance
  k8s:
    state: present
    namespace: "{{ namespace }}"
    definition: "{{ lookup('template', 'prometheus-instance.yaml.j2') | from_yaml }}"
📌 Template (templates/prometheus-instance.yaml.j2):
apiVersion: monitoring.coreos.com/v1
kind: Prometheus
metadata:
  name: prometheus
  namespace: {{ namespace }}
spec:
  replicas: 1
  serviceAccountName: prometheus-user
  serviceMonitorSelector: {}
  remoteWrite:
    - url: "{{ remote_write_url }}"
