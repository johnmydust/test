

---

defaults/main.yaml

monitoring_namespace: observability

remote_write:
  url: "https://your-remote-prometheus/api/v1/write"
  username: "your_username"
  password: "your_password"

kube_state_metrics:
  name: kube-state-metrics
  image: quay.io/coreos/kube-state-metrics:v2.10.1
  port: 8080

node_exporter:
  name: node-exporter
  image: quay.io/prometheus/node-exporter:v1.7.0
  port: 9100


---

Updated tasks/kube_state_metrics.yaml

- name: Deploy kube-state-metrics from template
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    definition: "{{ lookup('template', 'kube-state-metrics.yaml.j2') | from_yaml }}"


---

templates/kube-state-metrics.yaml.j2

apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ kube_state_metrics.name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ kube_state_metrics.name }}
  template:
    metadata:
      labels:
        app: {{ kube_state_metrics.name }}
        app.kubernetes.io/name: kube-state-metrics
    spec:
      containers:
        - name: {{ kube_state_metrics.name }}
          image: {{ kube_state_metrics.image }}
          ports:
            - name: http-metrics
              containerPort: {{ kube_state_metrics.port }}

---
apiVersion: v1
kind: Service
metadata:
  name: {{ kube_state_metrics.name }}
  labels:
    app: {{ kube_state_metrics.name }}
    app.kubernetes.io/name: kube-state-metrics
spec:
  ports:
    - port: {{ kube_state_metrics.port }}
      name: http-metrics
      targetPort: http-metrics
  selector:
    app: {{ kube_state_metrics.name }}


---

Updated tasks/node_exporter.yaml

- name: Deploy node-exporter from template
  k8s:
    state: present
    namespace: "{{ monitoring_namespace }}"
    definition: "{{ lookup('template', 'node-exporter.yaml.j2') | from_yaml }}"


---

templates/node-exporter.yaml.j2

apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: {{ node_exporter.name }}
spec:
  selector:
    matchLabels:
      app: {{ node_exporter.name }}
  template:
    metadata:
      labels:
        app: {{ node_exporter.name }}
    spec:
      containers:
        - name: {{ node_exporter.name }}
          image: {{ node_exporter.image }}
          ports:
            - containerPort: {{ node_exporter.port }}
              name: metrics
          args:
            - "--path.procfs=/host/proc"
            - "--path.sysfs=/host/sys"
            - "--path.rootfs=/host/root"
          volumeMounts:
            - name: proc
              mountPath: /host/proc
              readOnly: true
            - name: sys
              mountPath: /host/sys
              readOnly: true
            - name: root
              mountPath: /host/root
              readOnly: true
      volumes:
        - name: proc
          hostPath:
            path: /proc
        - name: sys
          hostPath:
            path: /sys
        - name: root
          hostPath:
            path: /
---
apiVersion: v1
kind: Service
metadata:
  name: {{ node_exporter.name }}
  labels:
    app: {{ node_exporter.name }}
spec:
  selector:
    app: {{ node_exporter.name }}
  ports:
    - name: metrics
      port: {{ node_exporter.port }}
      targetPort: metrics


---

